# LLM Configuration (model-agnostic via OpenAI-compatible API)
LLM_BASE_URL=http://localhost:8080/v1
LLM_API_KEY=not-needed
LLM_MODEL=mlx-community/Qwen3.5-9B-MLX-4bit

# Service Ports
GATEWAY_PORT=8001
MCP_SERVER_PORT=8002
DASHBOARD_PORT=3000

# Redis
REDIS_URL=redis://localhost:6379/0

# MCP Server URL (used by gateway to proxy approved calls)
MCP_SERVER_URL=http://localhost:8002

# Gateway URL (used by MCP server for registration & agent for execution)
GATEWAY_URL=http://localhost:8001
